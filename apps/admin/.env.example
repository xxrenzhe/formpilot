# Next.js 在构建时读取这些公开变量（修改后需重新 build）。
NEXT_PUBLIC_BFF_URL=http://localhost:8787
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_EXTENSION_STORE_URL=https://chromewebstore.google.com/detail/formpilot/<extension-id>
NEXT_PUBLIC_SUPPORT_EMAIL=support@formpilot.ai
NEXT_PUBLIC_SUPPORT_WECHAT=formpilot_support
NEXT_PUBLIC_ALIPAY_ACCOUNT=pay@formpilot.ai
NEXT_PUBLIC_WECHAT_QR_SRC=/recharge/wechat-qr-placeholder.svg
NEXT_PUBLIC_ALIPAY_QR_SRC=/recharge/alipay-qr-placeholder.svg

# 生产建议：NEXT_PUBLIC_BFF_URL=https://api.formpilot.ai
# 生产建议：NEXT_PUBLIC_EXTENSION_STORE_URL=https://chromewebstore.google.com/detail/formpilot/<extension-id>
# 生产建议：NEXT_PUBLIC_WECHAT_QR_SRC=/recharge/wechat-qr.png
# 生产建议：NEXT_PUBLIC_ALIPAY_QR_SRC=/recharge/alipay-qr.png
# Admin login supports username "formpilot" (mapped to formpilot@formpilot.local).
