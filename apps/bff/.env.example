# ---- Runtime ----
NODE_ENV=development
PORT=8787
APP_BASE_URL=https://formpilot.ai
# 生产环境请改为明确白名单，如 https://formpilot.ai,https://admin.formpilot.ai
CORS_ORIGINS=*

# ---- Supabase ----
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# ---- AI ----
AI_PROVIDER=openai
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4o-mini
# ADS_ONLY_MODE=true 时，优先使用 AI_MODEL_ADS（未填则回退 AI_MODEL）
AI_MODEL_GENERAL=
AI_MODEL_ADS=
# Ads 单场景开关（生产建议保持 true）
ADS_ONLY_MODE=true

# ---- Business ----
FREE_SIGNUP_CREDITS=20
# 同一 IP 免费试用发放节流
TRIAL_IP_CLAIM_WINDOW_HOURS=24
TRIAL_IP_CLAIM_MAX_PER_WINDOW=4
# 全局上下文和 Context Pool 截断长度
GLOBAL_CONTEXT_LIMIT=6000
CONTEXT_POOL_LIMIT=12000
# 反馈自动调权（默认关闭，建议先人工观察再开启）
PROMPT_AUTO_WEIGHT_ENABLED=false
PROMPT_WEIGHT_DELTA_ACCEPT=0.01
PROMPT_WEIGHT_DELTA_REJECT=-0.02

# 可选：配置后可通过 x-admin-token 调用部分管理接口
ADMIN_TOKEN=

# ---- Startup Migrations ----
AUTO_RUN_MIGRATIONS=true
MIGRATIONS_DIR=infra/supabase/migrations
MIGRATION_DB_SSL=true
MIGRATION_DB_SSL_REJECT_UNAUTHORIZED=false

# ---- Bootstrap Admin (fixed in code) ----
