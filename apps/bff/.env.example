# ---- Runtime ----
NODE_ENV=development
PORT=8787
APP_BASE_URL=https://formpilot.ai
CORS_ORIGINS=*

# ---- Supabase ----
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# ---- AI ----
AI_PROVIDER=openai
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_MODEL_GENERAL=
AI_MODEL_ADS=

# ---- Business ----
FREE_SIGNUP_CREDITS=20
GLOBAL_CONTEXT_LIMIT=6000
CONTEXT_POOL_LIMIT=12000
PROMPT_AUTO_WEIGHT_ENABLED=false
PROMPT_WEIGHT_DELTA_ACCEPT=0.01
PROMPT_WEIGHT_DELTA_REJECT=-0.02

# 可选：配置后可通过 x-admin-token 调用部分管理接口
ADMIN_TOKEN=

# ---- Startup Migrations ----
AUTO_RUN_MIGRATIONS=true
MIGRATIONS_DIR=infra/supabase/migrations
MIGRATION_DB_SSL=true
MIGRATION_DB_SSL_REJECT_UNAUTHORIZED=false

